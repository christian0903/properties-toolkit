{
  "name": "properties-toolkit",
  "version": "1.0.0",
  "description": "Comprehensive property management for Obsidian",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "build": "esbuild main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --platform=node --target=es2018",
    "dev": "esbuild main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --platform=node --target=es2018 --watch",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.5.4",
    "@types/node": "^20.0.0",
    "obsidian": "github:obsidianmd/obsidian-api"
  }
}
